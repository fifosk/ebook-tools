{
  "id": "create_readiness",
  "name": "Apple Create Readiness",
  "description": "Login, open native Apple Create, and verify default source loading for Narrate EPUB, subtitle, and YouTube dubbing jobs",
  "steps": [
    {
      "action": "login",
      "screenshot": "after_login"
    },
    {
      "action": "navigate_tab",
      "tab": "Settings",
      "selector": "browseSectionSettingsButton",
      "screenshot": "settings_runtime_contract"
    },
    {
      "action": "assert_visible",
      "selector": "settingsCreateContractRow",
      "timeout": 20
    },
    {
      "action": "assert_value_contains",
      "selector": "settingsCreateContractRow",
      "text": "/api/books/options",
      "timeout": 20
    },
    {
      "action": "assert_value_contains",
      "selector": "settingsCreateContractRow",
      "text": "/api/books/jobs",
      "timeout": 20
    },
    {
      "action": "assert_value_contains",
      "selector": "settingsCreateContractRow",
      "text": "/api/pipelines/files",
      "timeout": 20
    },
    {
      "action": "assert_value_contains",
      "selector": "settingsCreateContractRow",
      "text": "/api/subtitles/delete-source",
      "timeout": 20
    },
    {
      "action": "assert_value_contains",
      "selector": "settingsCreateContractRow",
      "text": "/api/subtitles/jobs",
      "timeout": 20
    },
    {
      "action": "assert_value_contains",
      "selector": "settingsCreateContractRow",
      "text": "/api/subtitles/youtube/dub",
      "timeout": 20
    },
    {
      "action": "assert_visible",
      "selector": "settingsLibraryActionsContractRow",
      "timeout": 20
    },
    {
      "action": "assert_value_contains",
      "selector": "settingsLibraryActionsContractRow",
      "text": "/api/library/items",
      "timeout": 20
    },
    {
      "action": "assert_value_contains",
      "selector": "settingsLibraryActionsContractRow",
      "text": "/api/library/items/{job_id}/upload-source",
      "timeout": 20
    },
    {
      "action": "assert_value_contains",
      "selector": "settingsLibraryActionsContractRow",
      "text": "/api/library/isbn/lookup",
      "timeout": 20
    },
    {
      "action": "assert_visible",
      "selector": "settingsOfflineExportsContractRow",
      "timeout": 20
    },
    {
      "action": "assert_value_contains",
      "selector": "settingsOfflineExportsContractRow",
      "text": "/api/exports",
      "timeout": 20
    },
    {
      "action": "assert_value_contains",
      "selector": "settingsOfflineExportsContractRow",
      "text": "/api/exports/{export_id}/download",
      "timeout": 20
    },
    {
      "action": "assert_value_contains",
      "selector": "settingsOfflineExportsContractRow",
      "text": "interactive-text",
      "timeout": 20
    },
    {
      "action": "assert_visible",
      "selector": "settingsPlaybackStateContractRow",
      "timeout": 20
    },
    {
      "action": "assert_value_contains",
      "selector": "settingsPlaybackStateContractRow",
      "text": "/api/bookmarks/{job_id}",
      "timeout": 20
    },
    {
      "action": "assert_value_contains",
      "selector": "settingsPlaybackStateContractRow",
      "text": "/api/resume",
      "timeout": 20
    },
    {
      "action": "assert_value_contains",
      "selector": "settingsPlaybackStateContractRow",
      "text": "job_id",
      "timeout": 20
    },
    {
      "action": "navigate_tab",
      "tab": "Create",
      "selector": "browseSectionCreateButton",
      "screenshot": "create_tab"
    },
    {
      "action": "assert_visible",
      "selector": "appleBookCreateView",
      "timeout": 15
    },
    {
      "action": "assert_frame",
      "selector": "appleBookCreateSetupPane",
      "platforms": ["iPad"],
      "timeout": 15,
      "min_width": 180,
      "max_width": 340,
      "min_height": 360
    },
    {
      "action": "assert_frame",
      "selector": "appleBookCreateSettingsPane",
      "platforms": ["iPad"],
      "timeout": 15,
      "min_width": 420,
      "min_height": 360,
      "screenshot": "ipad_create_split_panes"
    },
    {
      "action": "assert_visible",
      "selector": "createJobTypePicker",
      "timeout": 15
    },
    {
      "action": "select_option",
      "selector": "createJobTypePicker",
      "text": "Generate",
      "timeout": 10
    },
    {
      "action": "assert_visible",
      "selector": "createBookTopicField",
      "timeout": 15
    },
    {
      "action": "assert_visible",
      "selector": "createBookTitleField",
      "timeout": 15
    },
    {
      "action": "assert_non_empty_value",
      "selector": "createBookAuthorField",
      "placeholder": "Author",
      "timeout": 15
    },
    {
      "action": "enter_text",
      "selector": "createGeneratedSourceBookTitleField",
      "text": "Inferno",
      "timeout": 15
    },
    {
      "action": "assert_value_contains",
      "selector": "createGeneratedSourceBookTitleField",
      "text": "Inferno",
      "timeout": 15
    },
    {
      "action": "enter_text",
      "selector": "createGeneratedSourceBookAuthorField",
      "text": "Dan Brown",
      "timeout": 15
    },
    {
      "action": "assert_value_contains",
      "selector": "createGeneratedSourceBookAuthorField",
      "text": "Dan Brown",
      "timeout": 15
    },
    {
      "action": "enter_text",
      "selector": "createGeneratedSourceBookGenreField",
      "text": "Conspiracy thriller",
      "timeout": 15
    },
    {
      "action": "assert_value_contains",
      "selector": "createGeneratedSourceBookGenreField",
      "text": "Conspiracy thriller",
      "timeout": 15
    },
    {
      "action": "enter_text",
      "selector": "createBookSummaryField",
      "text": "A symbologist follows clues across Europe.",
      "timeout": 15,
      "screenshot": "generated_book_continuation_context"
    },
    {
      "action": "assert_visible",
      "selector": "createBookSentenceStepper",
      "timeout": 15,
      "screenshot": "generated_book_defaults"
    },
    {
      "action": "assert_visible",
      "selector": "createBookAudioModePicker",
      "timeout": 15
    },
    {
      "action": "assert_visible",
      "selector": "createBookAudioBitratePicker",
      "timeout": 15
    },
    {
      "action": "assert_visible",
      "selector": "createBookWrittenModePicker",
      "timeout": 15
    },
    {
      "action": "assert_visible",
      "selector": "createBookOutputHtmlToggle",
      "timeout": 15
    },
    {
      "action": "assert_visible",
      "selector": "createBookOutputPdfToggle",
      "timeout": 15
    },
    {
      "action": "assert_visible",
      "selector": "createBookIllustrationsToggle",
      "timeout": 15
    },
    {
      "action": "tap",
      "selector": "createBookIllustrationsToggle",
      "unless_visible": "createBookImageNodeAvailabilityButton",
      "timeout": 15
    },
    {
      "action": "assert_visible",
      "selector": "createBookImageNodeAvailabilityButton",
      "timeout": 15
    },
    {
      "action": "assert_visible",
      "selector": "createBookSentencesPerFileStepper",
      "timeout": 15
    },
    {
      "action": "assert_visible",
      "selector": "createBookTranslationBatchSizeStepper",
      "timeout": 15,
      "screenshot": "generated_book_job_settings"
    },
    {
      "action": "assert_visible",
      "selector": "createBookThreadCountField",
      "timeout": 15
    },
    {
      "action": "assert_visible",
      "selector": "createBookQueueSizeField",
      "timeout": 15
    },
    {
      "action": "assert_visible",
      "selector": "createBookJobMaxWorkersField",
      "timeout": 15
    },
    {
      "action": "select_option",
      "selector": "createJobTypePicker",
      "text": "Narrate EPUB",
      "timeout": 10
    },
    {
      "action": "assert_visible",
      "selector": "createNarrateSourcePathField",
      "timeout": 20
    },
    {
      "action": "assert_non_empty_value",
      "selector": "createNarrateSourcePathField",
      "placeholder": "Server EPUB path",
      "timeout": 25,
      "screenshot": "narrate_epub_defaults"
    },
    {
      "action": "tap",
      "selector": "createNarrateDiscoveryDisclosure",
      "platforms": ["iPhone", "iPad"],
      "timeout": 15
    },
    {
      "action": "assert_visible",
      "selector": "createNarrateDiscoveryProviderPicker",
      "timeout": 15
    },
    {
      "action": "select_option",
      "selector": "createNarrateDiscoveryProviderPicker",
      "text": "Z-Library import",
      "timeout": 15
    },
    {
      "action": "assert_value_contains",
      "selector": "createNarrateDiscoveryMessage",
      "text": "Direct Z-Library automation is intentionally disabled",
      "timeout": 15,
      "screenshot": "narrate_discovery_attended_import"
    },
    {
      "action": "select_option",
      "selector": "createBookTargetLanguagePicker",
      "text": "Hindi",
      "timeout": 15,
      "screenshot": "narrate_target_hindi"
    },
    {
      "action": "select_option",
      "selector": "createJobTypePicker",
      "text": "Subtitles",
      "timeout": 10
    },
    {
      "action": "assert_visible",
      "selector": "createSubtitleSourcePathField",
      "timeout": 20
    },
    {
      "action": "assert_non_empty_value",
      "selector": "createSubtitleSourcePathField",
      "placeholder": "Server subtitle path",
      "timeout": 25,
      "screenshot": "subtitle_defaults"
    },
    {
      "action": "assert_visible",
      "selector": "createSubtitleOutputFormatPicker",
      "timeout": 15
    },
    {
      "action": "assert_visible",
      "selector": "createSubtitleWorkerCountStepper",
      "timeout": 15
    },
    {
      "action": "assert_visible",
      "selector": "createSubtitleBatchSizeStepper",
      "timeout": 15
    },
    {
      "action": "assert_visible",
      "selector": "createSubtitleTranslationProviderPicker",
      "timeout": 15,
      "screenshot": "subtitle_job_settings"
    },
    {
      "action": "select_option",
      "selector": "createJobTypePicker",
      "text": "YouTube Dub",
      "timeout": 10
    },
    {
      "action": "assert_visible",
      "selector": "createYoutubeVideoPathField",
      "timeout": 20
    },
    {
      "action": "assert_non_empty_value",
      "selector": "createYoutubeVideoPathField",
      "placeholder": "Video path",
      "timeout": 25
    },
    {
      "action": "assert_non_empty_value",
      "selector": "createYoutubeSubtitlePathField",
      "placeholder": "Subtitle path",
      "timeout": 25,
      "screenshot": "youtube_dub_defaults"
    },
    {
      "action": "assert_visible",
      "selector": "createYoutubeTargetHeightPicker",
      "timeout": 15
    },
    {
      "action": "assert_visible",
      "selector": "createYoutubeOriginalMixStepper",
      "timeout": 15
    },
    {
      "action": "assert_visible",
      "selector": "createYoutubeFlushSentencesStepper",
      "timeout": 15
    },
    {
      "action": "assert_visible",
      "selector": "createYoutubeTranslationBatchSizeStepper",
      "timeout": 15
    },
    {
      "action": "assert_visible",
      "selector": "createYoutubeSplitBatchesToggle",
      "timeout": 15
    },
    {
      "action": "assert_visible",
      "selector": "createYoutubePreserveAspectRatioToggle",
      "timeout": 15,
      "screenshot": "youtube_dub_job_settings"
    },
    {
      "action": "assert_visible",
      "selector": "createBookOpenWebCreateButton",
      "timeout": 15,
      "screenshot": "web_create_handoff"
    }
  ]
}
