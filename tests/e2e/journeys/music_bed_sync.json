{
  "id": "music_bed_sync",
  "name": "tvOS Music Bed Sync",
  "description": "Login, play a book, and assert tvOS remote Play/Pause keeps Apple Music bed and reader transport in sync",
  "steps": [
    {
      "action": "login",
      "screenshot": "music_bed_after_login"
    },
    {
      "action": "play_first_item",
      "platforms": ["iPad"],
      "unless_visible": "e2eMusicBedPlayButton",
      "screenshot": "music_bed_ipad_player_opened"
    },
    {
      "action": "assert_visible",
      "selector": "e2eMusicBedPlayButton",
      "platforms": ["iPad"],
      "timeout": 30
    },
    {
      "action": "tap",
      "selector": "e2eMusicBedPlayButton",
      "platforms": ["iPad"],
      "timeout": 10,
      "screenshot": "music_bed_ipad_music_play_tapped"
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "music=playing",
      "platforms": ["iPad"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "surface=reader",
      "platforms": ["iPad"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "sessionStable=true",
      "platforms": ["iPad"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "sessionLabel=mixing",
      "platforms": ["iPad"],
      "timeout": 10,
      "screenshot": "music_bed_ipad_session_stable"
    },
    {
      "action": "tap",
      "selector": "e2eMusicBedAutoResumeButton",
      "platforms": ["iPad"],
      "timeout": 10
    },
    {
      "action": "assert_value_key_at_least",
      "selector": "e2eMusicBedSyncStatus",
      "key": "autoResumeAlreadyPlaying",
      "min_value": 1,
      "platforms": ["iPad"],
      "timeout": 10,
      "screenshot": "music_bed_ipad_auto_resume_settled"
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "music=playing",
      "platforms": ["iPad"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "surface=reader",
      "platforms": ["iPad"],
      "timeout": 10
    },
    {
      "action": "go_back",
      "platforms": ["iPad"],
      "screenshot": "music_bed_ipad_returned_to_menu"
    },
    {
      "action": "assert_visible",
      "selector": "e2eMusicBedPauseButton",
      "platforms": ["tvOS"],
      "timeout": 30,
      "screenshot": "music_bed_player_opened"
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "reader=paused",
      "platforms": ["tvOS"],
      "timeout": 15,
      "screenshot": "music_bed_pause_observed"
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "reader=playing",
      "platforms": ["tvOS"],
      "timeout": 55,
      "screenshot": "music_bed_play_observed"
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "music=playing",
      "platforms": ["tvOS"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "surface=reader",
      "platforms": ["tvOS"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "fullscreen=blocked",
      "platforms": ["tvOS"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "sessionStable=true",
      "platforms": ["tvOS"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "sessionLabel=mixing",
      "platforms": ["tvOS"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "readerTransportCommands=0",
      "platforms": ["tvOS"],
      "timeout": 10
    },
    {
      "action": "press_remote_button",
      "button": "playPause",
      "platforms": ["tvOS"],
      "screenshot": "music_bed_remote_pause_pressed"
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "readerTransportCommands=1",
      "platforms": ["tvOS"],
      "timeout": 3
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "lastAction=pause",
      "platforms": ["tvOS"],
      "timeout": 3
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "reader=paused",
      "platforms": ["tvOS"],
      "timeout": 3,
      "screenshot": "music_bed_remote_pause_observed"
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "music=paused",
      "platforms": ["tvOS"],
      "timeout": 3
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "guard=true",
      "platforms": ["tvOS"],
      "timeout": 3
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "surface=reader",
      "platforms": ["tvOS"],
      "timeout": 3
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "fullscreen=blocked",
      "platforms": ["tvOS"],
      "timeout": 3
    },
    {
      "action": "wait",
      "ms": 1500,
      "platforms": ["tvOS"]
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "reader=paused",
      "platforms": ["tvOS"],
      "timeout": 3,
      "screenshot": "music_bed_remote_pause_hold_observed"
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "music=paused",
      "platforms": ["tvOS"],
      "timeout": 3
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "guard=true",
      "platforms": ["tvOS"],
      "timeout": 3
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "surface=reader",
      "platforms": ["tvOS"],
      "timeout": 3
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "fullscreen=blocked",
      "platforms": ["tvOS"],
      "timeout": 3
    },
    {
      "action": "press_remote_button",
      "button": "playPause",
      "platforms": ["tvOS"],
      "screenshot": "music_bed_guarded_remote_play_pressed"
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "readerTransportCommands=1",
      "platforms": ["tvOS"],
      "timeout": 3
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "lastAction=pause",
      "platforms": ["tvOS"],
      "timeout": 3
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "reader=paused",
      "platforms": ["tvOS"],
      "timeout": 3,
      "screenshot": "music_bed_guarded_remote_play_ignored"
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "music=paused",
      "platforms": ["tvOS"],
      "timeout": 3
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "guard=true",
      "platforms": ["tvOS"],
      "timeout": 3
    },
    {
      "action": "wait",
      "ms": 12500,
      "platforms": ["tvOS"]
    },
    {
      "action": "press_remote_button",
      "button": "playPause",
      "platforms": ["tvOS"],
      "screenshot": "music_bed_remote_play_pressed"
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "readerTransportCommands=2",
      "platforms": ["tvOS"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "lastAction=play",
      "platforms": ["tvOS"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "reader=playing",
      "platforms": ["tvOS"],
      "timeout": 15,
      "screenshot": "music_bed_remote_play_observed"
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "music=playing",
      "platforms": ["tvOS"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "surface=reader",
      "platforms": ["tvOS"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "guard=false",
      "platforms": ["tvOS"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "fullscreen=blocked",
      "platforms": ["tvOS"],
      "timeout": 10
    },
    {
      "action": "press_remote_button",
      "button": "playPause",
      "count": 2,
      "interval_ms": 150,
      "platforms": ["tvOS"],
      "screenshot": "music_bed_remote_double_pause_pressed"
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "readerTransportCommands=3",
      "platforms": ["tvOS"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "lastAction=pause",
      "platforms": ["tvOS"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "reader=paused",
      "platforms": ["tvOS"],
      "timeout": 10,
      "screenshot": "music_bed_remote_double_pause_observed"
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "music=paused",
      "platforms": ["tvOS"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "guard=true",
      "platforms": ["tvOS"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "fullscreen=blocked",
      "platforms": ["tvOS"],
      "timeout": 10
    },
    {
      "action": "wait",
      "ms": 12500,
      "platforms": ["tvOS"]
    },
    {
      "action": "press_remote_button",
      "button": "playPause",
      "platforms": ["tvOS"],
      "screenshot": "music_bed_remote_final_play_pressed"
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "readerTransportCommands=4",
      "platforms": ["tvOS"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "lastAction=play",
      "platforms": ["tvOS"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "reader=playing",
      "platforms": ["tvOS"],
      "timeout": 15,
      "screenshot": "music_bed_remote_final_play_observed"
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "music=playing",
      "platforms": ["tvOS"],
      "timeout": 10
    },
    {
      "action": "go_back",
      "platforms": ["tvOS"],
      "screenshot": "music_bed_returned_to_menu"
    }
  ]
}
