{
  "id": "music_bed_sync",
  "name": "tvOS Music Bed Sync",
  "description": "Login, play a book, and assert tvOS remote Play/Pause keeps Apple Music bed and reader transport in sync",
  "platforms": ["iPad", "tvOS"],
  "steps": [
    {
      "action": "login",
      "screenshot": "music_bed_after_login"
    },
    {
      "action": "play_first_item",
      "platforms": ["iPad"],
      "unless_visible": "e2eMusicBedPlayButton",
      "screenshot": "music_bed_ipad_player_opened"
    },
    {
      "action": "assert_visible",
      "selector": "e2eMusicBedPlayButton",
      "platforms": ["iPad"],
      "timeout": 30
    },
    {
      "action": "assert_value_key_at_least",
      "selector": "e2eMusicBedSyncStatus",
      "key": "autoplaySettled",
      "min_value": 1,
      "platforms": ["iPad"],
      "timeout": 30
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "autoplayPending=none",
      "platforms": ["iPad"],
      "timeout": 10
    },
    {
      "action": "tap",
      "selector": "e2eMusicBedPlayButton",
      "platforms": ["iPad"],
      "timeout": 10,
      "screenshot": "music_bed_ipad_music_play_tapped"
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "music=playing",
      "platforms": ["iPad"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "surface=reader",
      "platforms": ["iPad"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "sessionStable=true",
      "platforms": ["iPad"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "sessionLabel=mixing",
      "platforms": ["iPad"],
      "timeout": 10,
      "screenshot": "music_bed_ipad_session_stable"
    },
    {
      "action": "tap",
      "selector": "e2eMusicBedAutoResumeButton",
      "platforms": ["iPad"],
      "timeout": 10
    },
    {
      "action": "assert_value_key_at_least",
      "selector": "e2eMusicBedSyncStatus",
      "key": "autoResumeAlreadyPlaying",
      "min_value": 1,
      "platforms": ["iPad"],
      "timeout": 10,
      "screenshot": "music_bed_ipad_auto_resume_settled"
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "music=playing",
      "platforms": ["iPad"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "surface=reader",
      "platforms": ["iPad"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "sessionStable=true",
      "platforms": ["iPad"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "sessionLabel=mixing",
      "platforms": ["iPad"],
      "timeout": 10
    },
    {
      "action": "press_keyboard_key",
      "key": "space",
      "selector": "e2eKeyboardSpaceCommandButton",
      "platforms": ["iPad"],
      "timeout": 10,
      "screenshot": "music_bed_ipad_space_pause_pressed"
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "readerTransportCommands=1",
      "platforms": ["iPad"],
      "timeout": 3
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "lastAction=pause",
      "platforms": ["iPad"],
      "timeout": 3
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "reader=paused",
      "platforms": ["iPad"],
      "timeout": 3
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "music=paused",
      "platforms": ["iPad"],
      "timeout": 3
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "readerPause=true",
      "platforms": ["iPad"],
      "timeout": 3,
      "screenshot": "music_bed_ipad_space_pause_observed"
    },
    {
      "action": "press_keyboard_key",
      "key": "space",
      "selector": "e2eKeyboardSpaceCommandButton",
      "platforms": ["iPad"],
      "timeout": 10,
      "screenshot": "music_bed_ipad_space_resume_pressed"
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "readerTransportCommands=2",
      "platforms": ["iPad"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "lastAction=play",
      "platforms": ["iPad"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "reader=playing",
      "platforms": ["iPad"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "music=playing",
      "platforms": ["iPad"],
      "timeout": 10
    },
    {
      "action": "assert_value_contains",
      "selector": "e2eMusicBedSyncStatus",
      "text": "readerPause=false",
