{
  "id": "basic_playback",
  "name": "Basic Book Playback",
  "description": "Login, verify settings connection state, navigate to Jobs (Books), play a book, return to menu",
  "platforms": ["iPhone", "iPad", "tvOS"],
  "steps": [
    {
      "action": "login",
      "screenshot": "after_login"
    },
    {
      "action": "assert_visible",
      "selector": "browseSectionSearchButton",
      "timeout": 10
    },
    {
      "action": "assert_visible",
      "selector": "appVersionBadge",
      "timeout": 10
    },
    {
      "action": "assert_frame",
      "selector": "appVersionBadge",
      "timeout": 10,
      "min_width": 88,
      "min_height": 16,
      "max_height": 34,
      "min_aspect_ratio": 3.2
    },
    {
      "action": "assert_visible",
      "selector": "browseSectionCreateButton",
      "platforms": ["tvOS"],
      "timeout": 10
    },
    {
      "action": "navigate_tab",
      "tab": "Create",
      "selector": "browseSectionCreateButton",
      "platforms": ["tvOS"],
      "screenshot": "tvos_create_tab"
    },
    {
      "action": "assert_visible",
      "selector": "appleBookCreateView",
      "platforms": ["tvOS"],
      "timeout": 15
    },
    {
      "action": "assert_visible",
      "selector": "createJobTypePicker",
      "platforms": ["tvOS"],
      "timeout": 15
    },
    {
      "action": "navigate_tab",
      "tab": "Search",
      "selector": "browseSectionSearchButton",
      "screenshot": "search_tab"
    },
    {
      "action": "assert_visible",
      "selector": "combinedSearchPromptView",
      "timeout": 10
    },
    {
      "action": "enter_text",
      "selector": "combinedSearchField",
      "text": "zzzz-no-library-match-0000",
      "timeout": 10,
      "screenshot": "search_query_entered"
    },
    {
      "action": "assert_visible",
      "selector": "combinedSearchEmptyView",
      "timeout": 10
    },
    {
      "action": "navigate_tab",
      "tab": "Settings",
      "selector": "browseSectionSettingsButton",
      "screenshot": "settings_tab"
    },
    {
      "action": "assert_visible",
      "selector": "settingsAPIHostRow",
      "timeout": 10
    },
    {
      "action": "assert_visible",
      "selector": "settingsBackendRuntimeRow",
      "timeout": 10
    },
    {
      "action": "assert_visible",
      "selector": "settingsTokenStorageRow",
      "timeout": 10
    },
    {
      "action": "assert_visible",
      "selector": "appChangelogSummaryView",
      "timeout": 10
    },
    {
      "action": "navigate_tab",
      "tab": "Jobs",
      "selector": "browseSectionJobsButton",
      "screenshot": "jobs_tab"
    },
    {
      "action": "assert_visible",
      "selector": "browseSectionJobsButton",
      "timeout": 10
    },
    {
      "action": "select_filter",
      "filter": "Books",
      "screenshot": "books_filter"
    },
    {
      "action": "play_first_item",
      "screenshot": "player_opened",
      "skip_if_empty": true
    },
    {
      "action": "assert_visible",
      "selector": "interactiveReaderHeaderProgressPill",
      "timeout": 15
    },
    {
      "action": "assert_non_empty_value",
      "selector": "interactiveReaderHeaderProgressPill",
      "timeout": 10,
      "screenshot": "player_progress_pill_checked"
    },
    {
      "action": "exercise_player_remote",
      "screenshot": "player_remote_checked",
      "timeout": 10
    },
    {
      "action": "go_back",
      "screenshot": "returned_to_menu"
    },
    {
      "action": "assert_visible",
      "selector": "nowPlayingReturnButton",
      "platforms": ["tvOS"],
      "timeout": 10,
      "screenshot": "tvos_now_playing_return"
    }
  ]
}
