{
  "id": "basic_playback",
  "name": "Basic Book Playback",
  "description": "Login, verify settings connection state, navigate to Jobs (Books), play a book, return to menu",
  "steps": [
    {
      "action": "login",
      "screenshot": "after_login"
    },
    {
      "action": "assert_visible",
      "selector": "browseSectionSearchButton",
      "timeout": 10
    },
    {
      "action": "navigate_tab",
      "tab": "Search",
      "selector": "browseSectionSearchButton",
      "screenshot": "search_tab"
    },
    {
      "action": "assert_visible",
      "selector": "combinedSearchPromptView",
      "timeout": 10
    },
    {
      "action": "enter_text",
      "selector": "combinedSearchField",
      "text": "zzzz-no-library-match-0000",
      "timeout": 10,
      "screenshot": "search_query_entered"
    },
    {
      "action": "assert_visible",
      "selector": "combinedSearchEmptyView",
      "timeout": 10
    },
    {
      "action": "navigate_tab",
      "tab": "Settings",
      "selector": "browseSectionSettingsButton",
      "screenshot": "settings_tab"
    },
    {
      "action": "assert_visible",
      "selector": "settingsAPIHostRow",
      "timeout": 10
    },
    {
      "action": "assert_visible",
      "selector": "settingsTokenStorageRow",
      "timeout": 10
    },
    {
      "action": "navigate_tab",
      "tab": "Jobs",
      "selector": "browseSectionJobsButton",
      "screenshot": "jobs_tab"
    },
    {
      "action": "assert_visible",
      "selector": "browseSectionJobsButton",
      "timeout": 10
    },
    {
      "action": "select_filter",
      "filter": "Books",
      "screenshot": "books_filter"
    },
    {
      "action": "play_first_item",
      "screenshot": "player_opened",
      "skip_if_empty": true
    },
    {
      "action": "exercise_player_remote",
      "screenshot": "player_remote_checked",
      "timeout": 10
    },
    {
      "action": "go_back",
      "screenshot": "returned_to_menu"
    }
  ]
}
